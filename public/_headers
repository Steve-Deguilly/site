# Cloudflare Pages — security headers
# Doc : https://developers.cloudflare.com/pages/configuration/headers/

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  X-DNS-Prefetch-Control: on
  Link: <https://cal.com/steve-deguilly/30min>; rel="appointment"; title="Réserver un appel découverte de 30 minutes"
  Link: <https://linkedin.com/in/steve-deguilly>; rel="me"; title="Profil LinkedIn"
  Link: <mailto:steve@creastory.fr>; rel="author"; title="Email direct"

# Cache long pour les assets statiques versionnés Astro
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache court pour les images publiques (le hash n'est pas dans le nom)
/*.jpg
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
