---
// Îlot interactif de la démo "Chat sur document" (T3 + T4).
// UI + état + appel réseau au webhook n8n. La logique pure vit dans lib/demo/client.ts.
//
// ⚠ Sécurité : la réponse du modèle est NON FIABLE. Le markdown est rendu via marked → DOMPurify.sanitize
//   (DOMPurify retire scripts/handlers). JAMAIS d'innerHTML brut sur la sortie modèle.
// ⚠ Le refus hors-doc est produit par n8n ; ici on n'affiche QUE `answer`.
import { SUGGESTED_QUESTIONS, COPY, MAX_QUESTION_LEN, TURNSTILE_SITE_KEY } from '../lib/demo/config';
---

<section class="demo-chat" aria-label="Démonstration : questions sur le document">
  <!-- Questions suggérées (amorce) -->
  <div class="demo-suggested" role="group" aria-label="Questions suggérées">
    {SUGGESTED_QUESTIONS.map((q) => (
      <button type="button" class="demo-suggest" data-suggest>{q}</button>
    ))}
  </div>

  <form id="demo-form" class="demo-form">
    <label class="demo-field">
      <span class="sr-only">Votre question</span>
      <input
        id="demo-question"
        name="question"
        type="text"
        maxlength={MAX_QUESTION_LEN}
        autocomplete="off"
        placeholder={COPY.inputPlaceholder}
        required
      />
    </label>

    <!-- Widget Turnstile (site key publique ; le secret reste dans n8n) -->
    <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>

    <button id="demo-send" type="submit" class="btn-cta demo-send">{COPY.sendLabel}</button>
  </form>

  <p id="demo-status" class="demo-status" role="status" aria-live="polite" hidden>{COPY.statusWriting}</p>
  <div id="demo-answer" class="demo-answer" aria-live="polite"></div>
</section>

<style>
  .demo-chat {
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-bg-cream);
    padding: 32px;
  }
  @media (max-width: 767px) { .demo-chat { padding: 22px; border-radius: 12px; } }

  /* Questions suggérées — grille 3 colonnes (2 lignes de 3) */
  .demo-suggested {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 22px;
  }
  @media (max-width: 900px) { .demo-suggested { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .demo-suggested { grid-template-columns: 1fr; } }
  .demo-suggest {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.35;
    text-align: left;
    color: var(--color-primary);
    background: rgba(45,90,79,0.06);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 10px 14px;
    cursor: pointer;
    transition: border-color 150ms, background 150ms;
  }
  .demo-suggest:hover { border-color: var(--color-primary); background: rgba(45,90,79,0.1); }

  /* Formulaire */
  .demo-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .demo-field { display: block; }
  .demo-field input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--color-text-primary);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px 16px;
    transition: border-color 150ms;
  }
  .demo-field input:focus { outline: none; border-color: var(--color-primary); }
  .demo-field input:disabled { background: var(--color-surface-warm); cursor: not-allowed; }

  .demo-send { align-self: flex-start; padding: 12px 22px; font-size: 15px; }
  .demo-send:disabled { opacity: 0.55; cursor: not-allowed; }

  /* Statut "en train d'écrire" */
  .demo-status {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 20px 0 0;
  }
  .demo-status[hidden] { display: none; }

  /* Réponse (markdown rendu via marked + DOMPurify) */
  .demo-answer {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-text-primary);
    margin-top: 20px;
    overflow-wrap: anywhere;
  }
  .demo-answer:empty { margin-top: 0; }
  .demo-answer > :first-child { margin-top: 0; }
  .demo-answer > :last-child { margin-bottom: 0; }

  .demo-answer p { margin: 0 0 14px; }
  .demo-answer h1,
  .demo-answer h2,
  .demo-answer h3,
  .demo-answer h4 {
    font-family: var(--font-serif);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 22px 0 10px;
  }
  .demo-answer h1 { font-size: 22px; }
  .demo-answer h2 { font-size: 20px; }
  .demo-answer h3,
  .demo-answer h4 { font-size: 18px; }
  .demo-answer strong { font-weight: 600; color: var(--color-text-primary); }
  .demo-answer em { font-style: italic; }
  .demo-answer a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .demo-answer ul,
  .demo-answer ol { margin: 0 0 14px; padding-left: 22px; }
  .demo-answer li { margin: 4px 0; }
  .demo-answer li::marker { color: var(--color-primary); }
  .demo-answer code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface-warm);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .demo-answer pre {
    background: var(--color-surface-warm);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 14px 16px;
    overflow-x: auto;
    margin: 0 0 14px;
  }
  .demo-answer pre code { background: none; padding: 0; font-size: 13px; }
  .demo-answer blockquote {
    margin: 0 0 14px;
    padding-left: 14px;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-muted);
  }

  /* Accessibilité */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap; border: 0;
  }
</style>

<script>
  import {
    validateQuestion,
    buildPayload,
    hasQuotaLeft,
    mapHttpError,
    extractAnswer,
  } from '../lib/demo/client';
  import { WEBHOOK_URL, COPY } from '../lib/demo/config';
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';

  marked.setOptions({ gfm: true, breaks: true });

  /** Markdown (marked) → HTML sanitizé (DOMPurify retire scripts/handlers). Jamais d'innerHTML brut. */
  function renderAnswer(text: string): string {
    return DOMPurify.sanitize(marked.parse(text, { async: false }) as string);
  }

  // Turnstile s'injecte sur window via le script chargé par la page /demo.
  interface TurnstileWindow extends Window {
    turnstile?: {
      getResponse: () => string | undefined;
      reset: () => void;
    };
  }
  const t = window as TurnstileWindow;

  const form = document.getElementById('demo-form') as HTMLFormElement | null;
  const input = document.getElementById('demo-question') as HTMLInputElement | null;
  const sendBtn = document.getElementById('demo-send') as HTMLButtonElement | null;
  const status = document.getElementById('demo-status');
  const answer = document.getElementById('demo-answer');
  const suggestBtns = document.querySelectorAll<HTMLButtonElement>('[data-suggest]');

  if (form && input && sendBtn && status && answer) {
    let count = 0;

    // Questions suggérées → remplissent le champ (textContent, pas de HTML).
    suggestBtns.forEach((b) => {
      b.addEventListener('click', () => {
        input.value = b.textContent ?? '';
        input.focus();
      });
    });

    function lockForQuota() {
      input!.disabled = true;
      sendBtn!.disabled = true;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!hasQuotaLeft(count)) {
        answer!.textContent = COPY.quotaReached;
        lockForQuota();
        return;
      }

      const token = t.turnstile?.getResponse();
      if (!token) {
        answer!.textContent = COPY.needTurnstile;
        return;
      }

      const validation = validateQuestion(input!.value);
      if (!validation.ok) return; // champ requis + maxlength couvrent l'UX ; on n'envoie rien d'invalide.

      sendBtn!.disabled = true;
      status!.hidden = false;
      answer!.textContent = '';

      try {
        const res = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(buildPayload(validation.value, token)),
        });

        if (!res.ok) {
          answer!.textContent = mapHttpError(res.status);
        } else {
          const data = await res.json();
          // Markdown rendu puis sanitizé (anti-XSS conservé) — voir renderAnswer().
          answer!.innerHTML = renderAnswer(extractAnswer(data));
          count++;
        }
      } catch {
        answer!.textContent = COPY.errorNetwork;
      } finally {
        status!.hidden = true;
        // Token Turnstile à usage unique : reset pour préparer la question suivante.
        t.turnstile?.reset();
        if (hasQuotaLeft(count)) {
          sendBtn!.disabled = false;
        } else {
          lockForQuota();
        }
      }
    });
  }
</script>
