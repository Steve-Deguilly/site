---
const year = new Date().getFullYear();
---
<footer>
  <div class="container">

    <div class="footer-grid">

      <!-- Colonne 1 : Contact -->
      <div class="footer-col">
        <p class="col-label">Contact</p>
        <p class="footer-name">Steve Deguilly</p>
        <p class="footer-tagline">Directeur de Transformation Digitale freelance — Nice</p>
        <ul class="footer-contact-links">
          <li><a href="mailto:steve@creastory.fr">steve@creastory.fr</a></li>
          <li><a href="https://linkedin.com/in/steve-deguilly" target="_blank" rel="noopener">LinkedIn → steve-deguilly</a></li>
        </ul>
      </div>

      <!-- Colonne 2 : Navigation -->
      <div class="footer-col">
        <p class="col-label">Navigation</p>
        <ul class="footer-nav">
          <li><a href="/#aqui-title">Pour qui</a></li>
          <li><a href="/#domaines-title">Domaines d'intervention</a></li>
          <li><a href="/#approche">Mon approche</a></li>
          <li><a href="/#cas-concrets">Cas concrets</a></li>
          <li><a href="/maturite">Test de maturité</a></li>
          <li><a href="/projets">Réalisations</a></li>
          <li><a href="/sdd">Ma méthode (spec-driven)</a></li>
          <li><a href="/#apropos">À propos</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Accréditations -->
      <div class="footer-col">
        <p class="col-label">Accréditations</p>
        <a
          class="badge-francenum"
          href="https://www.francenum.gouv.fr/activateurs/creastory-conseil"
          target="_blank"
          rel="noopener"
          aria-label="Activateur France Num — voir la fiche Creastory Conseil"
        >
          <picture>
            <source srcset="/marques-filles-Activateur.avif" type="image/avif" />
            <img
              src="/marques-filles-Activateur.webp"
              alt="Activateur France Num"
              class="badge-img"
              width="100"
              height="91"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </a>
        <p class="badge-desc">Programme gouvernemental d'accompagnement numérique des PME</p>
      </div>

    </div>

    <!-- Barre légale -->
    <div class="footer-bottom">
      <p class="footer-meta">
        Steve Deguilly opère via <strong>Creastory Conseil</strong> · SIRET : 93182223300017 · Nice, France
      </p>
      <ul class="footer-legal">
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/confidentialite">Confidentialité</a></li>
        <li>© {year}</li>
      </ul>
    </div>

    <p class="footer-proof"><a href="/sdd">Conçu en méthode spec-driven</a> · Sans cookie ni tracking · Optimisé pour les moteurs IA</p>

  </div>
</footer>

<style>
  footer {
    background: var(--color-primary-deep);
    padding: 56px 0 32px;
    border-top: 1px solid rgba(245,241,234,0.08);
  }

  /* Grille 3 colonnes */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(245,241,234,0.08);
  }
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* Étiquettes de colonne */
  .col-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-on-dark-muted); /* #BBC5BD — 5.5:1 sur #1F4138 ✓ AA */
    margin: 0 0 14px;
  }

  /* Colonne Contact */
  .footer-name {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text-on-dark); /* #E8E1D0 — ~10:1 ✓ */
    margin: 0 0 6px;
  }
  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-on-dark-muted); /* 5.5:1 ✓ AA */
    margin: 0 0 16px;
    line-height: 1.5;
  }
  .footer-contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-contact-links a {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-on-dark); /* ~10:1 ✓ */
    text-decoration: none;
    transition: color 150ms;
  }
  .footer-contact-links a:hover { color: var(--color-bg-cream); }

  /* Colonne Navigation */
  .footer-nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-nav a {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-on-dark); /* ~10:1 ✓ */
    text-decoration: none;
    transition: color 150ms;
  }
  .footer-nav a:hover { color: var(--color-bg-cream); }

  /* Colonne Accréditations */
  .badge-francenum {
    display: inline-block;
    padding: 10px 14px;
    border: 1px solid rgba(245,241,234,0.15);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 150ms, background 150ms;
  }
  .badge-francenum:hover {
    border-color: rgba(245,241,234,0.3);
    background: rgba(245,241,234,0.05);
  }
  .badge-img {
    display: block;
    width: 100px;
    height: auto;
  }
  .badge-desc {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-text-on-dark-muted); /* 5.5:1 ✓ AA */
    margin: 12px 0 0;
    line-height: 1.5;
    max-width: 180px;
  }

  /* Barre légale */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding-top: 24px;
    flex-wrap: wrap;
  }
  .footer-meta {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-text-on-dark-muted); /* 5.5:1 ✓ AA */
    margin: 0;
  }
  .footer-meta strong {
    font-weight: 500;
    color: var(--color-text-on-dark); /* ~10:1 ✓ */
  }
  .footer-legal {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-legal li {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-text-on-dark-muted); /* 5.5:1 ✓ AA */
  }
  .footer-legal a {
    color: var(--color-text-on-dark-muted);
    text-decoration: none;
    transition: color 150ms;
  }
  .footer-legal a:hover { color: var(--color-text-on-dark); }
  @media (max-width: 600px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* Mention de preuve — une ligne discrète, sur toutes les pages */
  .footer-proof {
    margin: 20px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-text-on-dark-muted);
    text-align: center;
  }
  .footer-proof a {
    color: var(--color-text-on-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms;
  }
  .footer-proof a:hover { color: var(--color-bg-cream); }
</style>
