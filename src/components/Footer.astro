---
const year = new Date().getFullYear();
---
<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-logo">Steve Deguilly</div>
      <ul class="footer-links">
        <li><a href="mailto:sdeguilly@gmail.com">sdeguilly@gmail.com</a></li>
        <li><a href="https://linkedin.com/in/steve-deguilly" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="/projets">Tous les projets</a></li>
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/confidentialite">Confidentialité</a></li>
      </ul>
      <p class="footer-meta">
        © {year} Steve Deguilly · Creastory Conseil · Nice · SIRET en cours
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-primary-deep);
    padding: 40px 0;
    border-top: 1px solid rgba(245,241,234,0.08);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  @media (max-width: 767px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
  }
  .footer-logo {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 500;
    color: rgba(245,241,234,0.7);
  }
  .footer-links {
    display: flex;
    gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-family: var(--font-sans);
    font-size: 13px;
    color: rgba(245,241,234,0.5);
    text-decoration: none;
    transition: color 150ms;
  }
  .footer-links a:hover { color: rgba(245,241,234,0.9); }
  .footer-meta {
    font-family: var(--font-sans);
    font-size: 12px;
    color: rgba(245,241,234,0.3);
    margin: 0;
  }
</style>
