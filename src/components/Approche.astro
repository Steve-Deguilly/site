---
const steps = [
  {
    n: '01',
    title: 'Diagnostic',
    body: "J'analyse votre existant, vos freins, vos actifs cachés. Durée : 1 semaine. Livrable : rapport d'étonnement actionnable.",
  },
  {
    n: '02',
    title: 'Cadrage',
    body: "Feuille de route priorisée, business case, première maquette fonctionnelle. Vous décidez en connaissance de cause.",
  },
  {
    n: '03',
    title: 'Exécution',
    body: "Je pilote équipes internes et prestataires. J'arbitre, je code quand il faut. Livrables toutes les 2 semaines, reporting hebdo en COPIL. Anticipation des risques avant qu'ils ne deviennent des problèmes.",
  },
  {
    n: '04',
    title: 'Autonomisation',
    body: "Votre équipe reprend la main. Documentation, formation, passation. Je ne crée pas de dépendance.",
  },
];
---
<section class="section section-alt" id="approche" aria-labelledby="approche-title">
  <div class="container">
    <p class="section-tag">Mon approche</p>
    <h2 class="section-h2" id="approche-title">
      En 4 temps. Chaque étape livre quelque chose. Pas de tunnel.
    </h2>
    <div class="approche-timeline reveal">
      {steps.map((step) => (
        <div class="approche-step">
          <div class="approche-dot"><span class="approche-dot-num">{step.n}</span></div>
          <h3 class="approche-title">{step.title}</h3>
          <p class="approche-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .approche-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }
  .approche-timeline::before {
    content: '';
    position: absolute;
    top: 17px;
    left: calc(12.5% + 2px);
    right: calc(12.5% + 2px);
    height: 1px;
    background: var(--color-border);
  }
  @media (max-width: 767px) {
    .approche-timeline { grid-template-columns: 1fr; gap: 0; }
    .approche-timeline::before { display: none; }
  }

  .approche-step {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-right: 24px;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 767px) {
    .approche-step {
      display: grid;
      grid-template-columns: 36px 1fr;
      grid-template-rows: auto auto;
      gap: 0 16px;
      padding-right: 0;
      padding-bottom: 32px;
      position: relative;
    }
    .approche-step:last-child { padding-bottom: 0; }
    .approche-step::after {
      content: '';
      position: absolute;
      left: 17px;
      top: 36px;
      bottom: 0;
      width: 1px;
      background: var(--color-border);
    }
    .approche-step:last-child::after { display: none; }
  }

  .approche-dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .approche-dot-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-bg-cream);
    letter-spacing: 0;
  }
  .approche-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .approche-body {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }
  @media (max-width: 767px) {
    .approche-title { grid-column: 2; grid-row: 1; align-self: center; margin-bottom: 4px; }
    .approche-body  { grid-column: 2; grid-row: 2; }
    .approche-dot   { grid-column: 1; grid-row: 1 / 3; align-self: start; }
  }
</style>
