---
const domaines = [
  {
    title: 'Stratégie & cadrage',
    body: "Audit terrain, business case, feuille de route priorisée. Vous savez où aller — et combien ça coûte — avant d'investir.",
    icon: '<path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M3 14h7v7H3z"/><path d="M14 14h7v7h-7z"/>',
  },
  {
    title: 'IA & automatisation',
    body: "n8n, RAG, LLMs locaux et API, agents. J'industrialise les processus métier qui freinent vos équipes. En production, pas en POC.",
    icon: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
  },
  {
    title: 'Direction de projet',
    body: "Pilotage end-to-end, COPIL, multi-prestataires, gestion des risques. 18 ans d'exécution terrain.",
    icon: '<path d="M2 20h20M6 20V10M12 20V4M18 20v-6"/>',
  },
  {
    title: 'Conformité & sécurité',
    body: "RGPD, HDS, gouvernance des données. J'ai mis 150 000 utilisateurs en conformité et architecturé des plateformes de santé certifiées.",
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
];
---
<section class="section" aria-labelledby="domaines-title">
  <div class="container">
    <p class="section-tag">Domaines d'intervention</p>
    <h2 class="section-h2" id="domaines-title">Ce que je fais.<br />Concrètement.</h2>
    <div class="domaines-grid reveal">
      {domaines.map((d) => (
        <article class="domaine-card">
          <svg class="icon domaine-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={d.icon} />
          <h3 class="domaine-title">{d.title}</h3>
          <p class="domaine-body">{d.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .domaines-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 1023px) { .domaines-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; } }
  @media (max-width: 767px)  { .domaines-grid { grid-template-columns: 1fr; } }

  .domaine-card {
    background: var(--color-bg-cream);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: border-color 200ms, transform 200ms ease-out;
  }
  .domaine-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
  }
  .domaine-icon {
    color: var(--color-primary);
    width: 24px;
    height: 24px;
  }
  .domaine-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin: 0;
  }
  .domaine-body {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }
</style>
