---
const cards = [
  {
    title: 'Vous dirigez.<br/>Ça doit livrer.',
    sub: 'Dirigeants PME / ETI · 50 à 500 personnes',
    body: "Vous avez identifié un projet de transformation, mais l'exécution traîne. Vous cherchez quelqu'un qui pilote ET qui livre — pas un cabinet qui produit des slides.",
    icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  },
  {
    title: 'Vous arbitrez.<br/>Ça doit débloquer.',
    sub: 'DSI / DPO · grandes structures',
    body: "Un programme spécifique bloque (refonte SI, intégration IA, mise en conformité HDS/RGPD). Vous avez besoin d'un renfort senior pour débloquer, sans embaucher.",
    icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  },
  {
    title: 'Vous scalez.<br/>Ça doit tenir.',
    sub: 'Fondateurs scale-up · architecte fractionnel',
    body: "Votre produit grandit, votre dette technique aussi. Vous cherchez un architecte fractionnel qui combine vision stratégique et exécution.",
    icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
  },
];
---
<section class="section section-alt" aria-labelledby="aqui-title">
  <div class="container">
    <p class="section-tag">À qui je m'adresse</p>
    <h2 class="section-h2" id="aqui-title">Trois profils.<br />Une seule promesse.</h2>
    <div class="aqui-grid reveal">
      {cards.map((card) => (
        <article class="aqui-card">
          <svg class="icon aqui-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={card.icon} />
          <div>
            <h3 class="aqui-title" set:html={card.title}></h3>
            <p class="aqui-sub">{card.sub}</p>
          </div>
          <p class="aqui-body">{card.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .aqui-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 1023px) { .aqui-grid { grid-template-columns: 1fr; gap: 14px; } }

  .aqui-card {
    background: var(--color-bg-cream);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 200ms;
  }
  .aqui-card:hover { border-color: var(--color-primary); }

  .aqui-icon {
    width: 40px;
    height: 40px;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .aqui-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin: 0 0 6px;
  }
  .aqui-sub {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-cool);
    margin: 0;
  }
  .aqui-body {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }
</style>
