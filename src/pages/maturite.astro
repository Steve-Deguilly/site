---
// Page /maturite (« Test de maturité ») — Partie B : wrapper éditorial + SEO + GEO + FAQ + bloc preuve.
// ⚠ Contenu citable (intro, "comment ça marche", FAQ) = rendu côté serveur, HORS de l'îlot JS.
//    Le quiz (DiagnosticQuiz) est un îlot interactif hydraté par-dessus.
//    Interne (module lib/diagnostic/ + events analytics diagnostic_*) volontairement inchangé.
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import DiagnosticQuiz from '../components/DiagnosticQuiz.astro';
import { INTRO, HOW_IT_WORKS, FAQ } from '../lib/diagnostic/content';

const siteUrl = 'https://steve-deguilly.com';
const pageUrl = `${siteUrl}/maturite`;

// ── JSON-LD @graph (GEO) — rendu statique dans le <head> via slot="head" ──
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${pageUrl}/#webapp`,
      name: 'Test de maturité',
      url: pageUrl,
      description:
        'Test de maturité gratuit en 6 questions qui situe une entreprise sur deux axes (maturité et douleur) et renvoie un profil et des leviers d’action pour automatiser ses processus.',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'fr',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
      provider: { '@id': `${siteUrl}/#organization` },
      creator: { '@id': `${siteUrl}/#person` },
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}/#faq`,
      mainEntity: FAQ.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Test de maturité', item: `${pageUrl}/` },
      ],
    },
  ],
};
---
<Layout
  title="Test de maturité (automatisation) gratuit — Steve Deguilly"
  description="Évaluez en 6 questions la maturité et la douleur de votre organisation face à l'automatisation. Profil et leviers d'action concrets. Gratuit, sans email."
  canonical="/maturite"
  ogImage="/og-maturite.jpg"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <Navbar />

  <main>
    <!-- Header éditorial citable -->
    <header class="diag-header">
      <div class="container">
        <p class="diag-kicker">Outil gratuit · 2 minutes</p>
        <h1>Test de maturité<br />où en est votre entreprise ?</h1>
        <p class="diag-intro">{INTRO}</p>
      </div>
    </header>

    <!-- Comment ça marche (statique, citable) -->
    <section class="diag-how" aria-labelledby="diag-how-title">
      <div class="container">
        <h2 id="diag-how-title" class="section-tag-h2">Comment ça marche</h2>
        <ul class="diag-how-list">
          {HOW_IT_WORKS.map((step) => (
            <li>{step}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Le quiz (îlot interactif) — son CTA résultat clôt le parcours -->
    <section class="diag-quiz-section" aria-label="Questionnaire">
      <div class="container">
        <DiagnosticQuiz />
      </div>
    </section>

    <!-- FAQ citable (statique) -->
    <section class="diag-faq" aria-labelledby="diag-faq-title">
      <div class="container">
        <h2 id="diag-faq-title" class="section-tag-h2">Questions fréquentes</h2>
        <div class="diag-faq-list">
          {FAQ.map((item) => (
            <article class="diag-faq-item">
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Header (hero centré, largeur de lecture confortable) */
  .diag-header { padding: 64px 0 32px; text-align: center; }
  .diag-kicker {
    font-family: var(--font-sans);
    font-size: 12px; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 14px;
  }
  .diag-header h1 {
    font-family: var(--font-serif);
    font-size: 42px; font-weight: 500;
    letter-spacing: -0.02em; line-height: 1.08;
    color: var(--color-text-primary);
    margin: 0 auto 20px;
    /* max-width: 640px; */
  }
  .diag-intro {
    font-family: var(--font-sans);
    font-size: 17px; line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 auto;
    /* max-width: 640px; */
  }
  @media (max-width: 767px) {
    .diag-header { padding: 40px 0 24px; }
    .diag-header h1 { font-size: 30px; }
    .diag-intro { font-size: 16px; }
  }

  /* Section titles partagés */
  .section-tag-h2 {
    font-family: var(--font-serif);
    font-size: 26px; font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin: 0 0 24px;
  }

  /* Comment ça marche */
  .diag-how { padding: 24px 0 8px; }
  .diag-how-list {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px 32px;
  }
  @media (max-width: 900px) {
    .diag-how-list { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .diag-how-list { grid-template-columns: 1fr; }
  }
  .diag-how-list li {
    position: relative;
    padding-left: 26px;
    font-family: var(--font-sans);
    font-size: 15px; line-height: 1.5;
    color: var(--color-text-primary);
  }
  .diag-how-list li::before {
    content: '✓';
    position: absolute; left: 0;
    color: var(--color-primary);
    font-weight: 600;
  }
  /* Quiz */
  .diag-quiz-section { padding: 40px 0 20px; }

  /* FAQ */
  .diag-faq { padding: 64px 0 80px; }
  .diag-faq-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px 48px;
  }
  @media (max-width: 767px) {
    .diag-faq-list { grid-template-columns: 1fr; gap: 28px; }
  }
  .diag-faq-item h3 {
    font-family: var(--font-sans);
    font-size: 17px; font-weight: 500;
    color: var(--color-text-primary);
    margin: 0 0 8px;
    line-height: 1.4;
  }
  .diag-faq-item p {
    font-family: var(--font-sans);
    font-size: 15px; line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }
  @media (max-width: 767px) {
    .diag-faq { padding: 48px 0 64px; }
  }
</style>
