---
// Page /demo — démo "Chat sur document" (T5).
// Contenu citable rendu côté serveur ; l'interactif vit dans l'îlot <DemoChat>.
//
// ⚠ v1 « discrète » : noindex, hors menu, AUCUN point d'entrée depuis le site (URL partagée à la main).
//   Pas de lien GitHub en v1.
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import DemoChat from '../components/DemoChat.astro';
import { DOC_TITLE, COPY, CALCOM_URL, CNIL_PDF_URL } from '../lib/demo/config';

const siteUrl = 'https://steve-deguilly.com';
const pageUrl = `${siteUrl}/demo`;

// JSON-LD GEO — prêt pour le jour où le noindex sautera (sans effet tant que la page est noindex).
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${pageUrl}/#webapp`,
      name: 'Démo — Chat sur document',
      url: pageUrl,
      description:
        'Démonstration interactive : posez des questions en langage naturel sur un document (recommandations IA de la CNIL). Réponses sourcées du document, sans stockage, via un modèle européen.',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'fr',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
      provider: { '@id': `${siteUrl}/#organization` },
      creator: { '@id': `${siteUrl}/#person` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Démo — Chat sur document', item: `${pageUrl}/` },
      ],
    },
  ],
};
---
<Layout
  title="Démo — Chat sur document | Steve Deguilly"
  description="Démonstration interactive : interrogez un document en langage naturel. Réponses sourcées, sans stockage, modèle européen."
  canonical="/demo"
>
  <!-- v1 discrète : non indexable -->
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <!-- Turnstile : chargé sur cette page uniquement -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer slot="head"></script>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <Navbar />

  <main>
    <header class="demo-header">
      <div class="container">
        <p class="demo-kicker">Démo interactive</p>
        <h1>Posez vos questions à un document.</h1>
        <p class="demo-intro">
          Une preuve, pas une slide. L'assistant répond <strong>uniquement</strong> à partir du document
          chargé — s'il ne sait pas, il le dit. <br>Souverain, sans stockage, modèle européen.
        </p>
        <p class="demo-doc">
          <span class="chip"><span class="chip-dot" aria-hidden="true"></span>Vous interrogez&nbsp;: {DOC_TITLE}</span>
        </p>
      </div>
    </header>

    <section class="demo-section" aria-label="Démonstration">
      <div class="container">
        <DemoChat />

        <!-- Bandeau RGPD + attribution (citable, rendu serveur) -->
        <p class="demo-rgpd">
          {COPY.rgpd} {COPY.attributionPrefix}{' '}
          <a href={CNIL_PDF_URL} target="_blank" rel="noopener" class="demo-cnil-link">CNIL</a>{' '}
          {COPY.attributionSuffix}
        </p>
      </div>
    </section>

    <!-- Comment ça marche — schéma du pipeline (SVG inline, classes/ids préfixés pipe- pour éviter toute collision) -->
    <section class="demo-how" aria-label="Comment fonctionne la démo">
      <div class="container">
        <figure id="demo-pipe" class="demo-pipe">
          <svg viewBox="0 0 1120 450" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pipe-ttl pipe-dsc">
            <title id="pipe-ttl">Pipeline de la démo de chat documentaire</title>
            <desc id="pipe-dsc">Cinq étapes : question du visiteur, vérification anti-robot Turnstile, injection du document CNIL sans RAG, génération par Mistral (modèle européen), puis réponse sourcée ou refus si l'information n'est pas dans le document. Une branche montre le blocage si la vérification anti-robot échoue.</desc>
            <style>
              .pipe-bg{fill:#F5F1EA;}
              .pipe-card{fill:#EBE5D9;stroke:#2D5A4F;stroke-width:1.5;}
              .pipe-card-ai{fill:#EBE5D9;stroke:#A55E2D;stroke-width:2;}
              .pipe-numc{fill:#2D5A4F;}
              .pipe-numc-ai{fill:#A55E2D;}
              .pipe-num{font-family:'JetBrains Mono',ui-monospace,monospace;fill:#F5F1EA;font-weight:700;font-size:14px;}
              .pipe-ttl-t{font-family:Fraunces,Georgia,serif;fill:#1A2421;font-size:27px;font-weight:600;}
              .pipe-h{font-family:Inter,system-ui,sans-serif;fill:#1A2421;font-weight:600;font-size:16px;}
              .pipe-sub{font-family:Inter,system-ui,sans-serif;fill:#5A625E;font-size:12.5px;}
              .pipe-cap{font-family:Inter,system-ui,sans-serif;fill:#5A625E;font-size:13.5px;}
              .pipe-refus{fill:#F5F1EA;stroke:#5A625E;stroke-width:1.4;stroke-dasharray:5 4;}
              .pipe-lbl{font-family:Inter,system-ui,sans-serif;fill:#5A625E;font-size:11.5px;font-style:italic;}
              .pipe-flow{stroke:#2D5A4F;stroke-width:2;fill:none;}
              .pipe-flow-d{stroke:#5A625E;stroke-width:1.6;fill:none;stroke-dasharray:5 4;}
            </style>
            <defs>
              <marker id="pipe-ah" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#2D5A4F"/>
              </marker>
              <marker id="pipe-ahd" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#5A625E"/>
              </marker>
            </defs>

            <rect class="pipe-bg" x="0" y="0" width="1120" height="450"/>

            <text class="pipe-ttl-t" x="40" y="56">Comment fonctionne la démo</text>

            <line class="pipe-flow" x1="216" y1="196" x2="246" y2="196" marker-end="url(#pipe-ah)"/>
            <line class="pipe-flow" x1="428" y1="196" x2="458" y2="196" marker-end="url(#pipe-ah)"/>
            <line class="pipe-flow" x1="640" y1="196" x2="670" y2="196" marker-end="url(#pipe-ah)"/>
            <line class="pipe-flow" x1="852" y1="196" x2="882" y2="196" marker-end="url(#pipe-ah)"/>

            <path class="pipe-flow-d" d="M338,248 L338,300" marker-end="url(#pipe-ahd)"/>
            <text class="pipe-lbl" x="348" y="276">échec</text>

            <rect class="pipe-card" x="36" y="144" width="180" height="104" rx="14"/>
            <circle class="pipe-numc" cx="60" cy="168" r="14"/>
            <text class="pipe-num" x="60" y="173" text-anchor="middle">1</text>
            <text class="pipe-h" x="126" y="196" text-anchor="middle">Question</text>
            <text class="pipe-sub" x="126" y="218" text-anchor="middle">Le visiteur interroge</text>

            <rect class="pipe-card" x="248" y="144" width="180" height="104" rx="14"/>
            <circle class="pipe-numc" cx="272" cy="168" r="14"/>
            <text class="pipe-num" x="272" y="173" text-anchor="middle">2</text>
            <text class="pipe-h" x="338" y="196" text-anchor="middle">Anti-robot</text>
            <text class="pipe-sub" x="338" y="218" text-anchor="middle">Turnstile · Cloudflare</text>

            <rect class="pipe-card" x="460" y="144" width="180" height="104" rx="14"/>
            <circle class="pipe-numc" cx="484" cy="168" r="14"/>
            <text class="pipe-num" x="484" y="173" text-anchor="middle">3</text>
            <text class="pipe-h" x="550" y="196" text-anchor="middle">Document CNIL</text>
            <text class="pipe-sub" x="550" y="218" text-anchor="middle">injecté, sans RAG</text>

            <rect class="pipe-card-ai" x="672" y="144" width="180" height="104" rx="14"/>
            <circle class="pipe-numc-ai" cx="696" cy="168" r="14"/>
            <text class="pipe-num" x="696" y="173" text-anchor="middle">4</text>
            <text class="pipe-h" x="762" y="196" text-anchor="middle">Mistral</text>
            <text class="pipe-sub" x="762" y="218" text-anchor="middle">modèle européen</text>

            <rect class="pipe-card" x="884" y="144" width="180" height="104" rx="14"/>
            <circle class="pipe-numc" cx="908" cy="168" r="14"/>
            <text class="pipe-num" x="908" y="173" text-anchor="middle">5</text>
            <text class="pipe-h" x="974" y="196" text-anchor="middle">Réponse</text>
            <text class="pipe-sub" x="974" y="218" text-anchor="middle">sourcée, ou « non couvert »</text>

            <rect class="pipe-refus" x="258" y="300" width="160" height="58" rx="12"/>
            <text class="pipe-h" x="338" y="326" text-anchor="middle" font-size="14px">Requête bloquée</text>
            <text class="pipe-sub" x="338" y="345" text-anchor="middle">robot détecté</text>

            <text class="pipe-cap" x="40" y="416">Aucune donnée stockée  ·  modèle européen (Mistral)  ·  orchestré avec n8n</text>
          </svg>
        </figure>
      </div>
    </section>

    <!-- CTA Cal.com (en plus du CTA permanent de la navbar) -->
    <section class="demo-cta section-dark" aria-label="Prendre rendez-vous">
      <div class="container">
        <h2 class="demo-cta-title">Envie de ça sur vos propres process&nbsp;?</h2>
        <p class="demo-cta-text">
          Cette démo tourne sur un document public. Sur vos documents métier, le même principe industrialise
          des process entiers. Parlons-en.
        </p>
        <a href={CALCOM_URL} target="_blank" rel="noopener" class="btn-cta demo-cta-btn">{COPY.ctaPrimary} →</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .demo-header { padding: 64px 0 24px; text-align: center; }
  .demo-kicker {
    font-family: var(--font-sans);
    font-size: 12px; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 14px;
  }
  .demo-header h1 {
    font-family: var(--font-serif);
    font-size: 42px; font-weight: 500;
    letter-spacing: -0.02em; line-height: 1.08;
    color: var(--color-text-primary);
    margin: 0 auto 20px;
  }
  .demo-intro {
    font-family: var(--font-sans);
    font-size: 17px; line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 auto 20px;
  }
  .demo-intro strong { color: var(--color-text-primary); font-weight: 500; }
  .demo-doc { margin: 0; }
  @media (max-width: 767px) {
    .demo-header { padding: 40px 0 20px; }
    .demo-header h1 { font-size: 30px; }
    .demo-intro { font-size: 16px; }
  }

  .demo-section { padding: 24px 0 64px; }

  .demo-rgpd {
    font-family: var(--font-sans);
    font-size: 13px; line-height: 1.6;
    color: var(--color-text-muted);
    margin: 20px 0 0;
    text-align: center;
  }
  .demo-cnil-link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms;
  }
  .demo-cnil-link:hover { color: var(--color-primary); }

  /* Comment ça marche — schéma pipeline */
  .demo-how { padding: 8px 0 56px; }
  .demo-pipe {
    max-width: 1040px;
    margin: 0 auto;
  }
  .demo-pipe svg {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 767px) { .demo-how { padding: 0 0 40px; } }

  /* CTA final */
  .demo-cta { text-align: center; }
  .demo-cta-title {
    font-family: var(--font-serif);
    font-size: 32px; font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-text-on-dark);
    margin: 0 0 16px;
  }
  .demo-cta-text {
    font-family: var(--font-sans);
    font-size: 16px; line-height: 1.65;
    color: var(--color-text-on-dark-muted);
    margin: 0 auto 28px;
  }
  .demo-cta-btn { font-size: 15px; padding: 13px 24px; }
  @media (max-width: 767px) {
    .demo-cta-title { font-size: 26px; }
  }
</style>
