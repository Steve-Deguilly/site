---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Mentions légales — Steve Deguilly"
  description="Mentions légales de steve-deguilly.com : éditeur Steve Deguilly (Creastory Conseil, SIRET, Nice), directeur de la publication, hébergeur Cloudflare et contact."
  canonical="/mentions-legales"
  ogImage="/og-mentions-legales.jpg"
>
  <Navbar />

  <main class="legal-page">
    <div class="container">
      <h1>Mentions légales</h1>

      <section>
        <h2>Éditeur du site</h2>
        <p>
          <strong>Steve Deguilly</strong>, opérant sous l'enseigne commerciale
          <strong>Creastory Conseil</strong>.<br />
          Adresse professionnelle : Nice, France.<br />
          Email : <a href="mailto:steve@creastory.fr">steve@creastory.fr</a><br />
          SIRET : 93182223300017
        </p>
      </section>

      <section>
        <h2>Directeur de la publication</h2>
        <p>Steve Deguilly</p>
      </section>

      <section>
        <h2>Hébergement</h2>
        <p>
          Le site <strong>steve-deguilly.com</strong> est hébergé par<br />
          <strong>Cloudflare, Inc.</strong><br />
          101 Townsend St, San Francisco, CA 94107, États-Unis<br />
          <a href="https://www.cloudflare.com" target="_blank" rel="noopener">www.cloudflare.com</a>
        </p>
      </section>

      <section>
        <h2>Propriété intellectuelle</h2>
        <p>
          L'ensemble des contenus présents sur ce site (textes, images, logos, photographies)
          est la propriété de Steve Deguilly, sauf mention contraire. Toute reproduction,
          représentation, modification ou exploitation, totale ou partielle, est interdite
          sans autorisation écrite préalable.
        </p>
      </section>

      <section>
        <h2>Crédits</h2>
        <p>
          Conception et développement : Steve Deguilly.<br />
          Polices : Fraunces, Inter, JetBrains Mono (Google Fonts, licence SIL Open Font).
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          Pour toute question relative au site ou au respect de la vie privée :
          <a href="mailto:steve@creastory.fr">steve@creastory.fr</a>
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page {
    padding: 64px 0 96px;
  }
  .legal-page h1 {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-text-primary);
    margin: 0 0 48px;
  }
  .legal-page section {
    margin-bottom: 36px;
    max-width: 720px;
  }
  .legal-page h2 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 12px;
  }
  .legal-page p {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin: 0;
  }
  .legal-page a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .legal-page a:hover { text-decoration: underline; }
  @media (max-width: 767px) {
    .legal-page { padding: 40px 0 64px; }
    .legal-page h1 { font-size: 32px; margin-bottom: 32px; }
  }
</style>
