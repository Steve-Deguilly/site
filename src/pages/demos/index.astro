---
// Hub /demos — « Démos & POC ». Liste les preuves interactives et POC anonymisés.
// Piloté par src/data/demos.ts : ajouter une entrée + une page src/pages/demos/<slug>.astro.
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CTAFinal from '../../components/CTAFinal.astro';
import DemoCatBlock from '../../components/DemoCatBlock.astro';
import { demos, categories } from '../../data/demos';

const siteUrl = 'https://steve-deguilly.com';
const pageUrl = `${siteUrl}/demos`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${pageUrl}/#collection`,
      name: 'Démos & POC',
      url: pageUrl,
      description:
        "Démos interactives et preuves de concept signées Steve Deguilly : automatisation n8n, IA souveraine, RAG. Des preuves qu'on peut essayer, pas des slides.",
      inLanguage: 'fr',
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#person` },
    },
    {
      '@type': 'ItemList',
      '@id': `${pageUrl}/#list`,
      itemListElement: demos.map((d, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: d.title,
        url: `${siteUrl}/demos/${d.slug}`,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}/#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Démos & POC', item: `${pageUrl}/` },
      ],
    },
  ],
};
---
<Layout
  title="Démos & POC — des preuves, pas des slides | Steve Deguilly"
  description="Démos interactives et preuves de concept : automatisation n8n, IA souveraine, RAG. Des preuves qu'on peut essayer plutôt que des promesses."
  canonical="/demos"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <Navbar />

  <main>
    <header class="page-header">
      <div class="container">
        <p class="page-kicker">Démos &amp; POC</p>
        <h1>Des preuves, pas des slides.</h1>
        <p class="page-intro">
          Je préfère montrer. Voici des démos que vous pouvez essayer en ligne et des preuves de
          concept livrées pour de vrais besoins — anonymisées quand il le faut. Chacune illustre la
          même approche&nbsp;: de l'IA souveraine, de l'automatisation, et des projets qui passent en
          production.
        </p>
      </div>
    </header>

    <section class="demos-section" aria-label="Démos et POC par usage">
      <div class="container">
        <div class="demos-cols">
          <div class="demos-col">
            <DemoCatBlock cat={categories[0]} />
          </div>
          <div class="demos-col">
            {categories.slice(1).map((cat) => <DemoCatBlock cat={cat} />)}
          </div>
        </div>
        <p class="demos-note">D'autres démos et POC viendront s'ajouter, par usage.</p>
      </div>
    </section>

    <CTAFinal />
  </main>

  <Footer />
</Layout>

<style>
  /* Header — même gabarit que /projets et /diagnostic */
  .page-header { padding: 64px 0 32px; text-align: center; }
  .page-kicker {
    font-family: var(--font-sans);
    font-size: 12px; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 14px;
  }
  .page-header h1 {
    font-family: var(--font-serif);
    font-size: 42px; font-weight: 500;
    letter-spacing: -0.02em; line-height: 1.08;
    color: var(--color-text-primary);
    margin: 0 auto 20px;
  }
  .page-intro {
    font-family: var(--font-sans);
    font-size: 17px; line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 auto;
  }
  @media (max-width: 767px) {
    .page-header { padding: 40px 0 24px; }
    .page-header h1 { font-size: 30px; }
    .page-intro { font-size: 16px; }
  }

  .demos-section { padding: 8px 0 24px; }

  /* 2 colonnes : gauche = 1re rubrique · droite = rubriques suivantes empilées. Mobile <900px = 1 colonne. */
  .demos-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 32px;
    align-items: start;
  }
  .demos-col {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  @media (max-width: 900px) {
    .demos-cols { grid-template-columns: 1fr; }
  }

  .demos-note {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-muted);
    text-align: center;
    margin: 36px 0 0;
  }
</style>
