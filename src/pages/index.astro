---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import PourQui from '../components/PourQui.astro';
import DomainesIntervention from '../components/DomainesIntervention.astro';
import Approche from '../components/Approche.astro';
import CasConcrets from '../components/CasConcrets.astro';
import APropos from '../components/APropos.astro';
import DiagnosticTeaser from '../components/DiagnosticTeaser.astro';
import DemosTeaser from '../components/DemosTeaser.astro';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Steve Deguilly — Architecte IA & Automatisation freelance"
  description="RAG souverain, n8n, LLMs sécurisés. 18 ans à automatiser les processus métier qui freinent vos équipes. Freelance — Nice, Monaco, Sophia Antipolis."
  canonical="/"
>
  <Navbar />
  <main>
    <Hero />
    <PourQui />
    <DomainesIntervention />
    <Approche />
    <CasConcrets />
    <APropos />
    <section class="section home-teasers" aria-label="Outils gratuits">
      <div class="container">
        <div class="home-teasers-grid">
          <DiagnosticTeaser />
          <DemosTeaser />
        </div>
      </div>
    </section>
    <CTAFinal />
  </main>
  <Footer />
</Layout>

<style>
  /* Teasers Diagnostic + Démos & POC côte à côte (2 colonnes), empilés en mobile. */
  .home-teasers-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: stretch;
  }
  @media (max-width: 767px) {
    .home-teasers-grid { grid-template-columns: 1fr; gap: 44px; }
  }
</style>
