---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'Steve Deguilly — Architecte IA & Automatisation (RAG, n8n, LLMs souverains)',
  description = "RAG souverain, n8n, LLMs sécurisés. 18 ans à automatiser les processus métier qui freinent vos équipes. Freelance — Nice, Monaco, Sophia Antipolis.",
  ogImage = '/og-image.jpg',
  canonical = Astro.url.pathname,
} = Astro.props;

const siteUrl = 'https://steve-deguilly.com';
// Canonical avec slash final pour coller aux URL du sitemap (format directory d'Astro).
const canonicalPath = canonical === '/' ? '/' : `${canonical.replace(/\/+$/, '')}/`;
const fullCanonical = `${siteUrl}${canonicalPath}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Steve Deguilly" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Theme color -->
  <meta name="theme-color" content="#F5F1EA" />

  <!-- Preload LCP image on home only (AVIF first, JPG fallback via <picture>) -->
  {canonical === '/' && (
    <link rel="preload" as="image" href="/profil-steve-deguilly.avif" type="image/avif" fetchpriority="high" />
  )}

  <!-- Fonts (chargement non bloquant) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </noscript>

  <!-- JSON-LD — entités globales (Person + Organization), référencées par @id sur toutes les pages -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": `${siteUrl}/#person`,
        "name": "Steve Deguilly",
        "jobTitle": "Architecte IA & Automatisation",
        "url": siteUrl,
        "image": `${siteUrl}/profil-steve-deguilly.jpg`,
        "email": "sdeguilly@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Nice",
          "addressCountry": "FR"
        },
        "knowsAbout": [
          "Automatisation des processus",
          "n8n",
          "RAG",
          "LLM",
          "Transformation digitale",
          "RGPD",
          "HDS"
        ],
        "sameAs": [
          "https://linkedin.com/in/steve-deguilly"
        ],
        "worksFor": { "@id": `${siteUrl}/#organization` }
      },
      {
        "@type": "ProfessionalService",
        "@id": `${siteUrl}/#organization`,
        "name": "Creastory Conseil",
        "url": siteUrl,
        "email": "sdeguilly@gmail.com",
        "founder": { "@id": `${siteUrl}/#person` },
        "areaServed": "France",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Nice",
          "addressCountry": "FR"
        },
        "identifier": {
          "@type": "PropertyValue",
          "propertyID": "SIRET",
          "value": "93182223300017"
        },
        "sameAs": ["https://linkedin.com/in/steve-deguilly"]
      },
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        "url": siteUrl,
        "name": "Steve Deguilly",
        "inLanguage": "fr",
        "publisher": { "@id": `${siteUrl}/#organization` }
      }
    ]
  })} />

  <!-- Balises <head> additionnelles spécifiques à la page (ex. JSON-LD GEO) -->
  <slot name="head" />
</head>
<body>
  <slot />

  <!-- Reveal animation observer -->
  <script>
    const revealEls = document.querySelectorAll('.reveal');
    if (revealEls.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });
      revealEls.forEach(el => observer.observe(el));
    } else {
      revealEls.forEach(el => el.classList.add('visible'));
    }
  </script>
  <!-- Suivi des points d'entrée vers /diagnostic (délégué, toutes pages) -->
  <script>
    import { track, ANALYTICS_EVENTS } from '../lib/diagnostic/analytics';
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      const entry = target?.closest<HTMLElement>('[data-diag-entry]');
      if (entry) {
        track(ANALYTICS_EVENTS.entryClick, { source: entry.dataset.diagEntry || '' });
      }
    });
  </script>

  <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "9e52449fe86c4b11b3f721fc64e9ec1f"}'></script>
  <!-- End Cloudflare Web Analytics -->
</body>
</html>
